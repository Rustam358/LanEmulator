<Window x:Class="LanEmulator.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LanEmulator"
        Width="860" Height="600"
        MinWidth="680" MinHeight="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border x:Name="WindowBorder" Background="#1E1E2E" CornerRadius="12">
    <Grid Margin="1">
        <!-- Title bar + tabs -->
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" x:Name="TitleBar" Background="#181825" MouseLeftButtonDown="TitleBar_Drag">
            <TextBlock Text="LanEmulator v1.3.2" Foreground="#6C7086" FontSize="12"
                       VerticalAlignment="Center" Margin="14,0,0,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="─" Style="{StaticResource TitleButton}"
                        Click="BtnMinimize_Click" ToolTip="Minimize"/>
                <Button x:Name="BtnMaximize" Content="□" Style="{StaticResource TitleButton}"
                        Click="BtnMaximize_Click" ToolTip="Maximize"/>
                <Button Content="✕" Style="{StaticResource TitleButton}"
                        Click="BtnClose_Click" ToolTip="Close"/>
            </StackPanel>
        </Grid>

        <!-- Tab bar -->
        <Grid Grid.Row="1" Background="#181825">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button x:Name="TabHome" Content="Home" Width="80"
                        Click="TabHome_Click"
                        Background="#313244" Foreground="#CDD6F4"
                        BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                        Cursor="Hand"/>
                <Button x:Name="TabDiagnostics" Content="Diagnostics" Width="110"
                        Click="TabDiagnostics_Click"
                        Background="Transparent" Foreground="#6C7086"
                        BorderThickness="0" FontSize="12"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- Content pages -->
        <Grid Grid.Row="2">
            <!-- ═══ WELCOME PAGE ═══ -->
            <Grid x:Name="WelcomePage" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="&#x1F3AE;" FontSize="48" HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Virtual LAN for Gaming" FontSize="20"
                               FontWeight="SemiBold" Foreground="#CDD6F4"
                               HorizontalAlignment="Center" Margin="0,0,0,24"/>


                    <!-- Mode selector -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <RadioButton x:Name="RbSteam" Content="Steam + Goldberg" Foreground="#CDD6F4"
                                     FontSize="13" Margin="0,0,20,0" IsChecked="True"
                                     GroupName="ModeGroup"/>
                        <RadioButton x:Name="RbLan" Content="Pure LAN" Foreground="#CDD6F4"
                                     FontSize="13" GroupName="ModeGroup"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- Host button -->
                        <Button x:Name="BtnHostWelcome" Click="BtnHost_Click"
                                Width="200" Height="140" Margin="0,0,12,0"
                                Style="{StaticResource BigButton}" Tag="host">
                            <StackPanel>
                                <TextBlock Text="&#x1F3E0;" FontSize="32"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="HOST ROOM" FontSize="16"
                                           FontWeight="Bold" HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                                <TextBlock Text="Create a virtual LAN room" FontSize="11"
                                           Foreground="#6C7086" HorizontalAlignment="Center"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Join button -->
                        <Button x:Name="BtnJoinWelcome" Click="BtnJoin_Click"
                                Width="200" Height="140" Margin="12,0,0,0"
                                Style="{StaticResource BigButton}" Tag="join">
                            <StackPanel>
                                <TextBlock Text="&#x1F517;" FontSize="32"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="JOIN ROOM" FontSize="16"
                                           FontWeight="Bold" HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                                <TextBlock Text="Connect to another player’s room" FontSize="11"
                                           Foreground="#6C7086" HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Welcome page log (errors visible before entering lobby) -->
                <ListBox x:Name="LstWelcomeLog" Grid.Row="1"
                         Background="#181825" BorderThickness="0"
                         Foreground="#CDD6F4" FontFamily="Consolas" FontSize="11"
                         Margin="24,0,24,0"/>

                <!-- Bottom bar -->
                <Border Grid.Row="2" Background="#181825" Padding="12,8"
                        CornerRadius="0,0,10,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F50D;  Scanning LAN for servers…" FontSize="11"
                                   Foreground="#6C7086" x:Name="TxtDiscovery"/>
                        <Button Content="Enter URL manually" FontSize="11"
                                Background="Transparent" Foreground="#89B4FA"
                                Padding="8,2" Margin="12,0,0,0"
                                Click="BtnManualUrl_Click"
                                Style="{StaticResource LinkButton}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ LOBBY PAGE ═══ -->
            <Grid x:Name="LobbyPage" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <!-- Status bar -->
                <Border Grid.Row="0" Background="#181825" Padding="14,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot" Width="10" Height="10"
                                     Fill="#A6E3A1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtLobbyStatus" Text="Connected"
                                       Foreground="#A6E3A1" FontWeight="SemiBold"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text=" · " Foreground="#45475A" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtLobbyRoom" Text="Room: ----"
                                       Foreground="#89B4FA" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" · " Foreground="#45475A" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtLobbyIp" Text="10.13.37.1"
                                       Foreground="#A6E3A1" FontFamily="Consolas" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Content="&#x2715; Leave" Style="{StaticResource LinkButton}"
                                Foreground="#F38BA8" HorizontalAlignment="Right"
                                Click="BtnDisconnect_Click"/>
                    </Grid>
                </Border>

                <!-- Main content -->
                <Grid Grid.Row="1" Margin="14,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Players + Game -->
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Section: Players -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="PLAYERS" Foreground="#6C7086"
                                       FontSize="11" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtPlayerCount" Text="(0/20)"
                                       Foreground="#45475A" FontSize="11"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>

                        <ListBox x:Name="LstPlayers" Grid.Row="1"
                                 Background="#181825" BorderThickness="0"
                                 Foreground="#CDD6F4" FontSize="13"
                                 ItemContainerStyle="{StaticResource PlayerItemStyle}"/>

                        <!-- Section: Game -->
                        <Border Grid.Row="2" Background="#181825" Padding="12" Margin="0,8,0,0"
                                CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#x1F3AE;" FontSize="20"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="GAME" Foreground="#6C7086" FontSize="10"
                                               FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtSelectedGame" Text="No game selected"
                                               Foreground="#CDD6F4" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button Content="Browse" Width="60"
                                            Click="BtnBrowseGame_Click" Margin="0,0,6,0"
                                            Style="{StaticResource SmallButton}"/>
                                    <Button Content="▶ Play" Width="60"
                                            x:Name="BtnLaunch"
                                            Click="BtnLaunch_Click"
                                            Style="{StaticResource SmallButton}"
                                            Background="#A6E3A1" Foreground="#1E1E2E"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Right: Chat -->
                    <Border Grid.Column="1" Background="#181825" CornerRadius="8" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="CHAT" Foreground="#6C7086"
                                       FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>

                            <ListBox x:Name="LstChat" Grid.Row="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#CDD6F4" FontSize="12"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Margin="0,0,0,10"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtChatInput" Grid.Column="0"
                                         KeyDown="TxtChatInput_KeyDown"
                                         Background="#1E1E2E" BorderBrush="#45475A"
                                         Foreground="#CDD6F4" CaretBrush="#CDD6F4"
                                         Padding="10,8" FontSize="13"
                                         ToolTip="Type a message and press Enter"/>
                                <Button Content="Send" Grid.Column="1"
                                        Width="60" Margin="8,0,0,0"
                                        Click="BtnSendChat_Click"
                                        Background="#89B4FA" Foreground="#1E1E2E"
                                        FontWeight="SemiBold" FontSize="12"
                                        x:Name="BtnSendChat"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Log -->
                <Border Grid.Row="2" Background="#181825" Margin="14,0,14,10"
                        CornerRadius="6" Padding="12,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="LOG" Foreground="#6C7086" FontSize="10"
                                   FontWeight="Bold" Margin="0,0,0,4"/>
                        <ListBox x:Name="LstLog" Grid.Row="1"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#CDD6F4" FontFamily="Consolas" FontSize="11"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== DIAGNOSTICS PAGE ===== -->
            <Grid x:Name="DiagnosticsPage" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#181825" Padding="14,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F50D;" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="DIAGNOSTICS" Foreground="#CDD6F4"
                                   FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Content="Refresh" Width="70" Margin="16,0,0,0"
                                Click="BtnDiagRefresh_Click"
                                Background="#313244" Foreground="#89B4FA"
                                BorderThickness="0" FontSize="11" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Margin="14,10">
                    <StackPanel Background="#181825">
                        <!-- Game section -->
                        <Border Background="#1E1E2E" CornerRadius="6"
                                Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="&#x1F3AE; GAME" Foreground="#6C7086"
                                           FontSize="11" FontWeight="Bold"
                                           Margin="0,0,0,8"/>
                                <TextBlock x:Name="DiagGamePath"
                                           Text="No game selected"
                                           Foreground="#585B70" FontSize="12"
                                           FontFamily="Consolas" Margin="0,0,0,4"/>
                                <ListBox x:Name="DiagWarnings"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#F9E2AF"
                                         FontFamily="Consolas"
                                         FontSize="11" MaxHeight="140"/>
                            </StackPanel>
                        </Border>

                        <!-- Network section -->
                        <Border Background="#1E1E2E" CornerRadius="6"
                                Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="&#x1F310; NETWORK"
                                           Foreground="#6C7086" FontSize="11"
                                           FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DiagAdapter"
                                           Text="Adapter: checking..."
                                           Foreground="#CDD6F4" FontSize="12"
                                           FontFamily="Consolas" Margin="0,0,0,2"/>
                                <TextBlock x:Name="DiagIp"
                                           Text="IP: --"
                                           Foreground="#A6E3A1" FontSize="12"
                                           FontFamily="Consolas" Margin="0,0,0,2"/>
                                <TextBlock x:Name="DiagRoutes"
                                           Text="Routes: checking..."
                                           Foreground="#89B4FA" FontSize="12"
                                           FontFamily="Consolas"/>
                                <TextBlock x:Name="DiagDrvVer"
                                           Text="Wintun driver: --"
                                           Foreground="#585B70" FontSize="12"
                                           FontFamily="Consolas" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Room section -->
                        <Border Background="#1E1E2E" CornerRadius="6"
                                Padding="14">
                            <StackPanel>
                                <TextBlock Text="&#x1F3E0; ROOM"
                                           Foreground="#6C7086" FontSize="11"
                                           FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DiagRoomId"
                                           Text="Room: not connected"
                                           Foreground="#CDD6F4" FontSize="12"
                                           FontFamily="Consolas" Margin="0,0,0,2"/>
                                <TextBlock x:Name="DiagPeers"
                                           Text="Peers: --"
                                           Foreground="#A6E3A1" FontSize="12"
                                           FontFamily="Consolas" Margin="0,0,0,2"/>
                                <TextBlock x:Name="DiagPort"
                                           Text="UDP port: 51820"
                                           Foreground="#585B70" FontSize="12"
                                           FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
    </Border>
</Window>
