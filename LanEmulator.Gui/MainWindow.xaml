<Window x:Class="LanEmulator.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LanEmulator v1.1"
        Width="900" Height="620"
        MinWidth="750" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Closing="Window_Closing">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: Setup Panel ═══ -->
        <Border Grid.Row="0" Background="#282840" CornerRadius="6" Padding="10" Margin="0,0,0,6">
            <WrapPanel VerticalAlignment="Center">
                <Button x:Name="BtnHost" Content="Host Room" Click="BtnHost_Click"
                        Width="100" Margin="0,0,8,0"/>
                <Button x:Name="BtnJoin" Content="Join Room" Click="BtnJoin_Click"
                        Width="100" Margin="0,0,8,0"
                        Background="#45475A" Foreground="#CDD6F4"/>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Width="1" Height="24" Margin="8,0"/>

                <Label Content="Mode:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <RadioButton x:Name="RbSteam" Content="Steam+Goldberg" IsChecked="True"
                             Checked="Mode_Changed" Margin="0,0,10,0"/>
                <RadioButton x:Name="RbLan" Content="Pure LAN"
                             Checked="Mode_Changed"/>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Width="1" Height="24" Margin="8,0"/>

                <Label Content="Game:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="TxtGamePath" Width="240" VerticalAlignment="Center"
                         Margin="0,0,4,0"
                         ToolTip="Path to game executable (Steam mode only)"/>
                <Button x:Name="BtnBrowse" Content="…" Click="BtnBrowse_Click"
                        Width="30" Height="24" Padding="2,0"
                        Background="#45475A" Foreground="#CDD6F4"/>
            </WrapPanel>
        </Border>

        <!-- ═══ Row 1: Main content (Room/Players + Chat) ═══ -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: Room info + Players -->
            <Border Grid.Column="0" Background="#282840" CornerRadius="6" Padding="10"
                    Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ROOM" FontWeight="Bold" FontSize="12"
                               Foreground="#6C7086" Margin="0,0,0,8"/>

                    <Border Grid.Row="1" Background="#1A1A2E" CornerRadius="4" Padding="8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#F9E2AF"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="TxtStatus" Text="Not connected"
                                           Foreground="#F9E2AF" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtRoomId" Foreground="#89B4FA"
                                       FontSize="16" FontWeight="Bold" Margin="0,4,0,0"
                                       Text=""/>
                            <TextBlock x:Name="TxtServerUrl" Foreground="#6C7086"
                                       FontSize="11" Margin="0,2,0,0" Text=""/>
                            <TextBlock x:Name="TxtMyIp" Foreground="#A6E3A1"
                                       FontSize="11" Margin="0,2,0,0" Text=""/>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="2" Text="PLAYERS" FontWeight="Bold" FontSize="12"
                               Foreground="#6C7086" Margin="0,12,0,4"/>
                    <ListBox x:Name="LstPlayers" Grid.Row="3"
                             BorderThickness="0" Background="Transparent"
                             Foreground="#CDD6F4" FontSize="12"/>

                    <Button x:Name="BtnDisconnect" Grid.Row="4" Content="Disconnect"
                            Click="BtnDisconnect_Click"
                            Background="#F38BA8" Foreground="#1E1E2E"
                            Margin="0,8,0,0" Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- Right panel: Chat -->
            <Border Grid.Column="1" Background="#282840" CornerRadius="6" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="CHAT" FontWeight="Bold" FontSize="12"
                               Foreground="#6C7086" Margin="0,0,0,8"/>

                    <ListBox x:Name="LstChat" Grid.Row="1"
                             Background="#1A1A2E" BorderThickness="0"
                             Foreground="#CDD6F4" FontSize="12"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Margin="0,0,0,6"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtChatInput" Grid.Column="0"
                                 KeyDown="TxtChatInput_KeyDown"
                                 ToolTip="Type a message and press Enter"
                                 IsEnabled="False"/>
                        <Button x:Name="BtnSendChat" Grid.Column="1" Content="Send"
                                Click="BtnSendChat_Click" Width="60" Margin="6,0,0,0"
                                Background="#89B4FA" Foreground="#1E1E2E"
                                IsEnabled="False"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ Row 2: Log ═══ -->
        <Border Grid.Row="2" Background="#282840" CornerRadius="6" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="LOG" FontWeight="Bold" FontSize="12"
                           Foreground="#6C7086" Margin="0,0,0,4"/>
                <ListBox x:Name="LstLog" Grid.Row="1"
                         Background="#1A1A2E" BorderThickness="0"
                         Foreground="#CDD6F4" FontFamily="Consolas" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</Window>
